  "keyFeatures": [
    "AI chat builder that reads and writes code, sets up databases, and deploys apps",
    "Live preview that updates in real time as the AI makes changes",
    "Built-in authentication with email, Google, Microsoft, and SAML/SSO",
    "Stripe-backed commerce for subscriptions and one-time payments",
    "One-click publishing to a free subdomain or custom domain",
    "Mobile app generation and App Store publishing",
    "Serverless backend with API routes, scheduled functions, and cron jobs",
    "AI Gateway for adding AI features to published apps",
    "Built-in CDN file storage, email, and push notifications",
    "Version control with automatic GitHub commits"
  ],
  "publicApiSurface": [
    "Proyecta SDK — Commerce checkout session and entitlement checks",
    "Proyecta Auth — user authentication and role-based access",
    "AI Gateway — frontier LLM access for published app users",
    "Files & Media — CDN-backed file upload and storage",
    "Email — transactional email from a verified domain",
    "Push Notifications — Web Push to end-user devices",
    "Content Management — headless CMS collections and locales",
    "Backend API routes — serverless functions exposed as public endpoints",
    "Analytics — built-in dashboards for published apps",
    "Environments & Secrets — environment variable management"
  ]
